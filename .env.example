# Copy this file to .env and fill in real values before running locally or with Docker.
# .env is gitignored and must never be committed to the repository.

# Flask session signing key — use a long random string in production.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-string

# Path where the SQLite database file is stored inside the container.
# The docker-compose volume keeps this data alive across rebuilds.
DATABASE_PATH=/app/data/database.db

# ── Practice Lab (AI scoring) ────────────────────────────────────────────────

# Your Anthropic API key. Required to use the IT Support Practice Lab.
# Obtain one at https://console.anthropic.com/
# The rest of the application starts normally without this key.
ANTHROPIC_API_KEY=

# Claude model used for scenario generation and grading.
# Defaults to claude-haiku-4-5-20251001 if not set.
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Local estimated spend cap for the Practice Lab (in USD).
# The app will block new API calls once this threshold is reached.
# This is an ESTIMATE based on calls recorded by this application,
# not your official Anthropic account balance.
PRACTICE_BUDGET_USD=5.00

# Maximum total API calls (generations + gradings) per admin per day.
# Prevents accidental overuse. Resets at midnight.
PRACTICE_DAILY_API_CALL_LIMIT=40

# Maximum characters allowed in an admin's practice response.
PRACTICE_MAX_RESPONSE_CHARS=5000

# Token pricing used for cost estimates (USD per million tokens).
# Update if Anthropic changes pricing for your selected model.
CLAUDE_INPUT_COST_PER_MILLION=1.00
CLAUDE_OUTPUT_COST_PER_MILLION=5.00
